{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "x-country-block",
          "value": "true"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "NI"
        }
      ],
      "destination": "/403.html"
    }
  ]
}
